{
  "name": "codearena",
  "version": "1.0.0",
  "description": "CodeArena — Microclasse gamificada d'HTML/CSS/JS",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "server": "node src/server/index.js",
    "build": "vite build",
    "start": "node src/server/index.js",
    "test": "node --test test/*.test.js",
    "server:pm2": "pm2 start ecosystem.config.cjs",
    "server:pm2-stop": "pm2 delete codearena"
  },
  "dependencies": {
    "express": "4.22.2",
    "socket.io": "4.8.3",
    "socket.io-client": "4.8.3",
    "lucide": "1.23.0",
    "@fontsource/inter": "5.2.8",
    "sortablejs": "1.15.7",
    "dompurify": "3.4.11"
  },
  "devDependencies": {
    "vite": "7.3.6"
  }
}
