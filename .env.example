# CodeArena — environment variables
# En producció, `dotenv` carrega aquest fitxer (còpia'l a `.env`) a l'arrencada
# del servidor: `import 'dotenv/config'` és el primer import de
# src/server/index.js, així que les variables ja hi són quan es llegeixen PORT i
# ADMIN_SECRET. En local pots seguir passant-les per la shell si vols
# (`ADMIN_SECRET=... npm start`); dotenv no sobreescriu el que ja hi ha a
# l'entorn (override:false per defecte).

# Port on escolta el servidor Node. Per defecte 3000 si no s'estableix.
# EN PRODUCCIÓ: PORT=8011 — ha de coincidir amb el destí del reverse proxy de
# CloudPanel/Nginx (D-05/D-10). No l'estableixis enlloc més (ni a ecosystem.config.cjs):
# .env és l'única font de PORT en prod.
PORT=8011

# Secret compartit que el professor introdueix al panell Admin per obtenir el
# control d'administració (registrar equips, controlar el temporitzador,
# force-resync). OBLIGATÒRIA en producció: si no s'estableix, l'autenticació
# admin queda DESHABILITADA i qualsevol client pot reclamar el rol admin.
# Posa-hi un valor fort abans de desplegar rere Nginx.
ADMIN_SECRET=change-me
