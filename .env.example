# CodeArena — environment variables
# The server reads these straight from the process environment (no dotenv).
# Set them via your shell (`ADMIN_SECRET=... npm start`) or, in production,
# your process manager's env config (e.g. a PM2 ecosystem file's `env` block).

# Port the Node server listens on. Defaults to 3000 if unset.
PORT=3000

# Shared secret the teacher must enter in the Admin panel to gain admin control
# (register teams, control the timer, force-resync). REQUIRED in production:
# if unset, admin authentication is DISABLED and any client can claim the admin
# role. Set a strong value before deploying behind Nginx.
ADMIN_SECRET=change-me
